---
import BaseLayout from '@/layouts/base-layout.astro';
import MenuCategory from '@/components/menu/menu-category.astro';
import MenuNavigation from '@/components/menu/menu-navigation.astro';
import { rush } from '@/lib/rush';
import { RUSH_MENU_ID } from 'astro:env/server';
import type { RushMenuCategory } from '@/types/rush';

const menuCollectionId = RUSH_MENU_ID;
let categories: RushMenuCategory[] = [];

try {
  const response = await rush.entries.get(String(menuCollectionId), {
    per_page: 100,
    sort: 'sort_order'
  }) as any;
  categories = response.data || [];
} catch (error) {
  console.error("Error fetching digital menu:", error);
}
---

<BaseLayout title="Cardápio Digital | Esquina do Pão">
  <section class="pt-32 pb-24 bg-white relative overflow-hidden min-h-screen">
    <div class="absolute top-0 inset-x-0 h-[500px] bg-linear-to-b from-secondary/50 to-transparent pointer-events-none -z-10"></div>
    
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="text-primary font-medium tracking-wider uppercase mb-2 block">Nosso Sabor</span>
        <h1 class="text-5xl md:text-6xl font-serif font-bold text-dark mb-4">Cardápio</h1>
        <p class="text-lg text-dark/70 max-w-2xl mx-auto">
          Confira nossas opções fresquinhas e preparadas com muito carinho para você.
        </p>
      </div>

      {categories.length === 0 ? (
        <div class="text-center py-16 bg-white rounded-2xl shadow-sm border border-dark/5">
          <p class="text-xl text-dark/70">O cardápio está sendo atualizado. Volte em breve!</p>
        </div>
      ) : (
        <div class="space-y-16">
          {categories.map((category: RushMenuCategory) => (
            <MenuCategory category={category} />
          ))}
        </div>
      )}
      
      <MenuNavigation categories={categories} />

    </div>
  </section>
</BaseLayout>
