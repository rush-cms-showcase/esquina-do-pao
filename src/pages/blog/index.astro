---
import BaseLayout from '@/layouts/base-layout.astro';
import SectionHeading from '@/components/ui/section-heading.astro';
import { Image } from 'astro:assets';
import { rush } from '@/lib/rush';
import { RUSH_ROUTE_BLOG_ID } from 'astro:env/server';

const blogCollectionId = String(RUSH_ROUTE_BLOG_ID);
const response = await rush.entries.get(blogCollectionId, {
  per_page: 12,
  sort: '-published_at'
}) as any;

const posts = response.data || [];
---

<BaseLayout title="Blog | Esquina do Pão">
  <section class="pt-32 pb-24 bg-white relative overflow-hidden min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading 
        title="Nosso Blog" 
        subtitle="Novidades e Curiosidades da Padaria"
        titleColor="text-accent"
      />

      {posts.length === 0 ? (
        <div class="text-center py-16">
          <p class="text-xl text-dark/70">Nenhum post encontrado.</p>
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mt-12">
          {posts.map((post: any) => (
            <article class="bg-white rounded-2xl shadow-md overflow-hidden hover:shadow-xl transition-shadow flex flex-col h-full border border-dark/5">
              <a href={`/blog/${post.slug}`} class="block aspect-video overflow-hidden relative group">
                {post.cover?.url ? (
                  <Image 
                    src={post.cover.url} 
                    alt={post.title} 
                    width={800} 
                    height={450} 
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  />
                ) : (
                  <div class="w-full h-full bg-secondary flex items-center justify-center">
                    <span class="text-primary opacity-50 text-4xl">🍞</span>
                  </div>
                )}
                {post.taxonomies?.categorias?.[0] && (
                  <div class="absolute top-4 left-4 bg-primary text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider shadow-sm">
                    {post.taxonomies.categorias[0].title}
                  </div>
                )}
              </a>
              <div class="p-6 flex flex-col grow">
                <div class="text-sm text-dark/60 mb-3 font-medium">
                  {new Date(post.published_at).toLocaleDateString('pt-BR', {
                    day: '2-digit',
                    month: 'long',
                    year: 'numeric'
                  })}
                </div>
                <h3 class="text-xl font-serif font-bold text-dark mb-3 line-clamp-2 hover:text-primary transition-colors">
                  <a href={`/blog/${post.slug}`}>{post.title}</a>
                </h3>
                {post.excerpt && (
                  <p class="text-dark/70 line-clamp-3 mb-6 grow">{post.excerpt}</p>
                )}
                <div class="mt-auto pt-4 border-t border-dark/10">
                  <a href={`/blog/${post.slug}`} class="text-primary font-bold hover:text-accent transition-colors flex items-center gap-2">
                    Ler mais
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
