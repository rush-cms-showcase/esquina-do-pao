---
import type { RushMenuCategory } from '@/types/rush';

interface Props {
  categories: RushMenuCategory[];
}

const { categories = [] } = Astro.props;
---

{categories.length > 0 && (
  <nav class="mt-16 flex flex-wrap justify-center gap-3" aria-label="Navegação do Cardápio">
      {categories.map((category: RushMenuCategory) => (
          <a href={`#${category.slug}`} class="px-4 py-2 rounded-full bg-secondary text-dark/80 hover:bg-primary hover:text-white transition-colors text-sm font-medium shadow-sm">
              {category.title}
          </a>
      ))}
  </nav>
)}
