---
import type { RushMenuItem } from '@/types/rush';

interface Props {
  item: RushMenuItem;
}

const { item } = Astro.props;
---

<li class="group">
  <div class="flex flex-col sm:flex-row sm:items-baseline justify-between gap-2 sm:gap-4">
    
    {/* Left: Code, Name, Description */}
    <div class="flex-1 bg-white relative z-10 pr-4">
      <h3 class="text-xl font-bold text-dark group-hover:text-primary transition-colors inline-block">
        <span class="text-primary/70 mr-2 text-sm font-mono tracking-tighter">#{item.id}</span>
        {item.name}
      </h3>
      {item.description && (
        <p class="text-sm text-dark/60 mt-1 leading-snug max-w-xl">
          {item.description}
        </p>
      )}
    </div>

    {/* Dotted Line (hidden on very small screens, visible on sm+) */}
    <div class="hidden sm:block grow border-b-2 border-dotted border-dark/20 relative top-[-8px] mx-4 transition-colors group-hover:border-primary/30"></div>

    {/* Right: Prices */}
    <div class="shrink-0 bg-white relative z-10 pl-0 sm:pl-4 text-left sm:text-right mt-2 sm:mt-0">
      {item.price && item.price.length > 0 ? (
        item.price.length === 1 ? (
          /* Single Price */
          <span class="text-xl font-bold text-dark">
            {item.price[0].price}
          </span>
        ) : (
          /* Multiple Prices (Variants) */
          <div class="flex flex-col gap-1 items-start sm:items-end">
            {item.price.map((p: any) => (
              <div class="flex items-center gap-2">
                {p.name && (
                  <span class="text-xs text-dark/60 uppercase font-medium tracking-wider">{p.name}:</span>
                )}
                <span class="text-lg font-bold text-dark">{p.price}</span>
              </div>
            ))}
          </div>
        )
      ) : (
        <span class="text-sm font-medium text-dark/40 italic">Consulte</span>
      )}
    </div>
    
  </div>
</li>
