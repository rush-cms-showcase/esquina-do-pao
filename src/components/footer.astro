---
interface Props {
  menu?: any[]
}

const { menu = [] } = Astro.props
---

<footer class="bg-secondary pt-20 pb-10 border-t border-primary/10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
      <div class="md:col-span-1">
        <a href="/" class="flex items-center gap-3 mb-6">
          <img src="/esquina-do-pao-logo.png" alt="Esquina do Pão Logo" class="h-10 w-auto" />
          <span class="font-serif text-2xl font-bold text-primary">Esquina do Pão</span>
        </a>
        <p class="text-dark/70 pr-4">O verdadeiro sabor caseiro feito com dedicação e os melhores ingredientes.</p>
      </div>
        <h3 class="font-serif font-bold text-lg mb-6 text-dark">Links Rápidos</h3>
        <ul class="space-y-4">
          {menu.map((item) => (
            <li>
              <a href={item.url} target={item.target || '_self'} class="text-dark/70 hover:text-primary transition-colors">
                {item.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="font-serif font-bold text-lg mb-6 text-dark">Contato</h3>
        <ul class="space-y-4 text-dark/70">
          <li class="flex items-start gap-3">
            <svg class="h-6 w-6 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            <span>Av. Piauí, 500 - Jardim Primavera<br/>Caraguatatuba - SP<br/>CEP 11660-640</span>
          </li>
          <li class="flex items-center gap-3">
            <svg class="h-6 w-6 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            <span>(12) 3882-3792</span>
          </li>
        </ul>
      </div>
      <div>
        <h3 class="font-serif font-bold text-lg mb-6 text-dark">Horário</h3>
        <ul class="space-y-4 text-dark/70">
          <li class="flex justify-between border-b border-dark/10 pb-2">
            <span>Todos os Dias</span>
            <span class="font-medium">06:00 - 22:30</span>
          </li>
        </ul>
      </div>
    </div>
    <div class="border-t border-primary/20 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-dark/60 text-sm">
      <p>&copy; {new Date().getFullYear()} Esquina do Pão. Todos os direitos reservados.</p>
      <div class="flex space-x-4">
        <a href="#" class="hover:text-primary transition-colors">Instagram</a>
        <a href="#" class="hover:text-primary transition-colors">Facebook</a>
      </div>
    </div>
  </div>
</footer>
