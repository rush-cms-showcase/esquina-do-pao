---
import SectionHeading from '@/components/ui/section-heading.astro';

// [TODO] This data can be easily swapped out for an API fetch later
// e.g. const response = await fetch('https://api.exemplo.com/menu-preview');
// const menuCategories = await response.json();

const menuCategories = [
  {
    category: "Pães Quentinhos",
    items: [
      { name: "Pão Francês Tradicional", description: "Fornadas a cada hora, sempre crocante", price: "R$ 19,90/kg" },
      { name: "Pão de Queijo Especial", description: "A verdadeira receita mineira com muito queijo", price: "R$ 49,90/kg" },
      { name: "Broa de Milho Fofinha", description: "Com toque de erva doce, receita da vovó", price: "R$ 6,50/un" },
      { name: "Baguete Recheada", description: "Recheios variados: frango, calabresa e quatro queijos", price: "R$ 14,00/un" }
    ]
  },
  {
    category: "Lanches na Chapa",
    items: [
      { name: "Misto Quente Caprichado", description: "Pão francês, presunto de primeira e muita muçarela", price: "R$ 12,00" },
      { name: "Bauru Clássico", description: "Pão francês, rosbife caseiro, tomate, picles e queijo derretido", price: "R$ 24,00" },
      { name: "Pão na Chapa com Requeijão", description: "O clássico paulistano bem tostado", price: "R$ 8,00" },
      { name: "X-Tudo da Esquina", description: "Hambúrguer, queijo, presunto, bacon, ovo, alface e tomate", price: "R$ 28,00" }
    ]
  }
]
---

<section class="pt-24 bg-white relative overflow-hidden">
  <div class="absolute right-0 top-0 w-64 h-64 bg-secondary rounded-bl-full opacity-50 -z-10"></div>
  <div class="absolute left-0 bottom-0 w-48 h-48 bg-secondary rounded-tr-full opacity-50 -z-10"></div>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading 
      title="Dá água na boca" 
      subtitle="Um pedaço do nosso Cardápio"
      titleColor="text-accent"
    />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-16 gap-y-12 bg-white/50 backdrop-blur-md p-8 sm:p-12 pb-16 lg:pb-32 border border-primary/10 shadow-xl shadow-primary/5 border-b-none">
      <div class="absolute bottom-0 left-0 bg-linear-to-t from-white to-transparent w-full h-2/3 p-8 z-10 flex items-center justify-end flex-col">
      <div class="mt-16 text-center">
        <a href="#" class="inline-block bg-white text-primary border-2 border-primary px-8 py-4 rounded-full font-medium hover:bg-primary hover:text-white transition-all duration-300 shadow-md hover:shadow-lg text-lg">
          Ver o Cardápio Completo
        </a>
      </div>
    </div>
      {menuCategories.map((group) => (
        <div>
          <h3 class="w-full text-2xl font-serif font-bold text-primary mb-8 border-b-2 border-dashed border-primary/20 pb-2 inline-block">
            {group.category}
          </h3>
          <ul class="space-y-8">
            {group.items.map((item) => (
              <li class="cursor-default">
                <div class="flex justify-between items-baseline gap-4 mb-1">
                  <span class="font-bold font-serif text-lg text-dark">{item.name}</span>
                  <div class="grow border-b-2 border-dotted border-dark/20 relative top-[-6px]"></div>
                  <span class="font-bold text-lg text-primary shrink-0">{item.price}</span>
                </div>
                <p class="text-dark/70 text-sm leading-relaxed pr-16">{item.description}</p>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
