---
import SectionHeading from '@/components/ui/section-heading.astro';

interface Props {
  data?: any;
}

const { data = {} } = Astro.props;

const testimonials = Array.isArray(data.testimonials) && data.testimonials.length > 0
  ? data.testimonials
  : [
      {
        name: 'Custodio Ortiuti',
        role: 'Avaliação do Google',
        text: 'Vou sempre tomar café ou almoçar ou comer pizza, comida boa e atendimento muito bom, especialmente o Manoel que atende muito bem.',
      },
      {
        name: 'Eduardo Ferraioli',
        role: 'Avaliação do Google',
        text: 'O melhor lugar para almoçar, jantar e comprar um pão quentinho...',
      },
      {
        name: 'Daniela Christine',
        role: 'Avaliação do Google',
        text: 'Amo essa padaria. Destaque para as roscas de polvilho, pão de torresmo, esfihas dentre outras delícias (sempre descubro algo novo). Todas as vezes que vou à Caraguatatuba passo lá e compro tudo que vejo na frente hahaha. Super recomendo.',
      },
      {
        name: 'Beto Bolsam',
        role: 'Avaliação do Google',
        text: 'Excelente atendimento, ambiente agradável e ótimos produtos!',
      }
    ]
---

<section class="py-24 bg-dark text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <SectionHeading 
      title={data.testimonials_title || "Depoimentos"} 
      subtitle={data.testimonials_subtitle || "A Palavra de Nossos Clientes"} 
      titleColor="text-accent"
      theme="dark"
    />
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-5xl mx-auto">
      {testimonials.map((item: any) => (
        <div class="bg-white/5 backdrop-blur-sm gap-4 flex items-start justify-start flex-col p-10 rounded-2xl border border-white/10 text-left">
          <div class="flex text-accent">
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
          </div>
          <p class="text-xl leading-relaxed italic">"{item.text}"</p>
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center font-serif text-xl">
              {item.name.charAt(0)}
            </div>
            <div class="mt-auto">
              <p class="font-bold font-serif">{item.name}</p>
              <p class="text-white/60 text-sm">{item.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
